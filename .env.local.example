# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Stripe
# ===========================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (Stripe ダッシュボードで作成)
STRIPE_PRICE_BASIC_ASSESSMENT=price_...   # くわしいチェック 1,480円（一回払い）
STRIPE_PRICE_PLAN_30DAY=price_...         # 30日プラン 2,450円（一回払い）
STRIPE_PRICE_MONTHLY=price_...            # マンスリー 2,980円/月（サブスクリプション）

# ===========================================
# OpenAI
# ===========================================
OPENAI_API_KEY=sk-...

# ===========================================
# App
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 本番: NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
